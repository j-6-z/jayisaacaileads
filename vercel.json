{
  "crons": [
    {
      "path": "/api/cron/generate-article",
      "schedule": "0 13 * * *"
    }
  ],
  "rewrites": [
    { "source": "/blog", "destination": "/api/blog" },
    { "source": "/blog/:slug", "destination": "/api/blog/:slug" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap.xml" }
  ]
}
