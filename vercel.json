{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/stripe-webhook.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/stripe-webhook",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}